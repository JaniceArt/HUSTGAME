--- !u!114 &1748034141
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1748034140}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9e2e7047c31666749aff4a05ae907f49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NormalPhoneCallStep
  waitBeforeStart: 0
  objectiveTitle: 
  autoAdvanceNextStep: 0
  advanceDelay: 0
  phoneObject: {fileID: 74182629}
  ringSound: {fileID: 8300000, guid: 93d5fb258a376cd4289dc04b63ccb3c4, type: 3}
  hangUpSound: {fileID: 8300000, guid: 09abd436651ba2e4cae4ff9bfd8d1cfa, type: 3}
  objectiveText: "Nghe \u0111i\u1EC7n tho\u1EA1i \u0111ang reo"
  preCallDialog: []
  phoneVoiceDialog:
  - sentence: "Alo An \xE0, m\u1EA5y nay b\xE1n h\xE0ng \u0111\u01B0\u1EE3c kh\xF4ng
      ch\xE1u"
    hasChoices: 1
    choices:
    - choiceText: "D\u1EA1 c\u0169ng \u1ED5n \u1EA1, nh\u01B0ng m\xE0 kh\xE1ch \u1EDF
        \u0111\xE2y h\u01A1i k\xEC l\u1EA1 c\xF4 nh\u1EC9.."
      replyText: 
    - choiceText: "C\xF4 \u01A1i h\xECnh nh\u01B0 \u1EDF \u0111\xE2y c\xF3 ma"
      replyText: 
  - sentence: "B\u1ECB sao v\u1EADy ch\xE1u, c\xF3 ph\u1EA3i do c\xE1i th\u1EB1ng
      Tiktoker trong tr\u01B0\u1EDDng kh\xF4ng?"
    hasChoices: 1
    choices:
    - choiceText: "D\u1EA1? L\xE0 nh\u01B0 n\xE0o v\u1EADy c\xF4"
      replyText: 
    - choiceText: "\u0110\xF3 l\xE0 ai v\u1EADy \u1EA1?"
      replyText: 
  - sentence: "C\xF3 th\u1EB1ng nh\xF3c c\u1EE9 hay quay m\u1EA5y tr\xF2 d\u1ECDa
      ma \u0111\u0103ng tiktok ki\u1EBFm fame "
    hasChoices: 0
    choices: []
  - sentence: "V\xEC n\xF3 m\xE0 m\u1EA5y nh\xE2n vi\xEAn c\u1EE7a c\xF4 ngh\u1EC9
      vi\u1EC7c r\u1ED3i, m\xE0 kh\xF4ng l\u1ED9 m\u1EB7t n\xEAn kh\xF4ng b\u1EAFt
      \u0111\u01B0\u1EE3c n\xF3"
    hasChoices: 0
    choices: []
  - sentence: "\xC0 c\xF4 c\xF3 vi\u1EC7c r\u1ED3i, t\xED c\xF4 g\u1ECDi l\u1EA1i
      nh\xE9"
    hasChoices: 0
    choices: []
  afterCallDialog:
  - sentence: "L\u1EBD n\xE0o t\u1EA5t c\u1EA3 nh\u1EEFng chuy\u1EC7n k\xEC d\u1ECB
      m\u1EA5y ng\xE0y qua \u0111\u1EC1u l\xE0 do n\xF3!"
    hasChoices: 0
    choices: []
